# ClaudeMaxPower — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# GitHub Personal Access Token
# Required for: fix-issue skill, review-pr skill, MCP GitHub integration
# Scopes needed: repo, read:org
GITHUB_TOKEN=ghp_your_token_here

# Sentry Integration
# Required for: MCP Sentry integration
SENTRY_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Database (optional — for DB-to-UI workflow examples)
DB_URL=postgresql://user:password@localhost:5432/mydb

# Default GitHub repository for skills (owner/repo format)
DEFAULT_REPO=your-username/your-repo
